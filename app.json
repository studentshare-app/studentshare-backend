{
  "expo": {
    "name": "StudentShare",
    "slug": "StudentShare",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "studentshare",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0F172A"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.koyaapps.StudentShare",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F172A",
          "dark": {
            "backgroundColor": "#0F172A"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1A56DB",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "StudentShare"
        }
      ],
      "expo-web-browser",
      "expo-audio",
      "expo-asset",
      "expo-secure-store",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3ca4e0b4-196e-460d-b14f-8c95827d28cb"
      },
      "expoPublic": {
        "supabaseUrl": "${EXPO_PUBLIC_SUPABASE_URL}",
        "supabaseAnonKey": "${EXPO_PUBLIC_SUPABASE_ANON_KEY}"
      }
    },
    "owner": "studentshare",
    "runtimeVersion": "1.0.1",
    "updates": {
      "url": "https://u.expo.dev/3ca4e0b4-196e-460d-b14f-8c95827d28cb"
    }
  }
}